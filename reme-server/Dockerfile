FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml /app/pyproject.toml
COPY src /app/src

RUN python -m pip install -U pip setuptools wheel && pip install .

ENV REME_WORKING_DIR=/data/reme
ENV REME_LLM_BACKEND=openai
ENV REME_LLM_MODEL_NAME=qwen3.5-plus
ENV REME_EMBEDDING_BACKEND=openai
ENV REME_EMBEDDING_MODEL_NAME=text-embedding-v4
ENV REME_EMBEDDING_DIMENSIONS=1024
ENV REME_VECTOR_BACKEND=chroma
ENV REME_CHROMA_HOST=chroma
ENV REME_CHROMA_PORT=8000
ENV REME_CHROMA_COLLECTION=reme
ENV REME_AUTO_START=1

VOLUME ["/data"]
EXPOSE 8090

CMD ["reme-server", "--host", "0.0.0.0", "--port", "8090"]