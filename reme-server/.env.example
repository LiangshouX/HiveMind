# ===== ReMe Environment Variables =====
# Copy this file to .env and fill in real values. Do NOT commit .env to version control.
#
# These variables are read by ReMe's config system via ${VAR:-default} syntax in
# reme/config/default.yaml. The start scripts load .env via python-dotenv.
#
# ReMe is started via CLI args (service.backend, mcp.transport, log.level, service.port).
# These env vars only control LLM/Embedding credentials and optional API key auth.

# ----- LLM Configuration (Required) -----
# Used by auto_memory, auto_dream, and other LLM-powered steps.
# Supports any OpenAI-compatible API (DashScope, DeepSeek, etc.)
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-max

# ----- Embedding Configuration (Optional) -----
# Used for vector search. If omitted, ReMe falls back to BM25 keyword search only.
# Can be the same provider as LLM or a separate embedding service.
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL_NAME=text-embedding-v4

# ----- API Key Authentication (Optional) -----
# If set, all ReMe HTTP/MCP requests must include: Authorization: Bearer <key>
# If omitted, authentication is disabled.
# REME_API_KEY=your-secret-key-here
