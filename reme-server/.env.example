# ReMe Server 配置示例

# API Key 认证（可选，不设置则禁用认证）
# 如果设置，客户端必须在 Authorization 头中提供正确的 API Key
# REME_API_KEY=your-secret-api-key-here

# ReMe 工作目录
REME_WORKING_DIR=.reme

# LLM 后端配置 - 默认使用阿里云百炼 (DashScope)
REME_LLM_BACKEND=dashscope
REME_LLM_MODEL_NAME=qwen-plus

# Embedding 后端配置 - 默认使用阿里云百炼 (DashScope)
REME_EMBEDDING_BACKEND=dashscope
REME_EMBEDDING_MODEL_NAME=text-embedding-v3
REME_EMBEDDING_DIMENSIONS=1536

# 向量后端配置 (chroma 或 local)
REME_VECTOR_BACKEND=chroma

# Chroma 向量数据库配置
REME_CHROMA_HOST=127.0.0.1
REME_CHROMA_PORT=8000
REME_CHROMA_COLLECTION=reme

# 环境变量说明：
# 1. REME_API_KEY: 设置后启用 API Key 认证，客户端需提供 Authorization: Bearer <api_key>
# 2. REME_VECTOR_BACKEND: 设置为 local 可不依赖 Chroma，使用本地向量存储
# 3. REME_LLM_BACKEND 和 REME_EMBEDDING_BACKEND: 支持 dashscope、openai 等
# 4. 阿里云百炼 (DashScope) 配置：
#    - 需要在环境变量中设置 DASHSCOPE_API_KEY
#    - LLM 模型可选：qwen-turbo, qwen-plus, qwen-max 等
#    - Embedding 模型可选：text-embedding-v3, text-embedding-v2 等
