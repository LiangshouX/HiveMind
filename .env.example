# ============================================================
# HiveMind - Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ----- MySQL Configuration -----
MYSQL_ROOT_PASSWORD=hivemind123

# ----- JWT Secret -----
JWT_SECRET=HiveMindJwtSecretKey2026ForDockerDeployment

# ----- LLM Configuration (Required) -----
# Alibaba Cloud DashScope API Key
AI_DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# LLM Provider: dashscope | deepseek | openai
TDAGENT_MODEL_PROVIDER=dashscope
TDAGENT_MODEL_NAME=qwen-max
TDAGENT_MODEL_ID=qwen3-max
TDAGENT_MODEL_BASE_URL=https://dashscope.aliyuncs.com

# ----- ReMe Memory Server LLM Config -----
# Used by ReMe server for embedding and memory operations
FLOW_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
FLOW_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding model (optional, defaults to same as LLM)
# FLOW_EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxx
# FLOW_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
